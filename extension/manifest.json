{
  "manifest_version": 2,
  "name": "VaultMate Passkey Combo",
  "version": "1.0",
  "description": "Companion extension for VaultMate GUI to intercept Passkey requests.",
  "permissions": [
    "nativeMessaging",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "vaultmate@local.dev"
    }
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    "page_script.js"
  ]
}
